# CrystalDrops Production Environment Variables

# Server
PORT=5000
# Use development locally so failed M-Pesa calls can fall back to mock STK (see paymentController).
NODE_ENV=development

# Database
# Provide your MongoDB Atlas URI here (e.g. mongodb+srv://<user>:<password>@cluster.mongodb.net/crystaldrops)
MONGO_URI=

# Authentication
# Secret key for signing JWT tokens. Use a strong, random string in production.
JWT_SECRET=your_super_secret_jwt_key

# M-Pesa Daraja (Safaricom) — code reads MPESA_* or DARAJA_* names
# Leave keys unset (or placeholder) for mock STK during local dev.
# MPESA_USE_MOCK=1 forces mock even if keys are set.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-backend-url.onrender.com/api/payments/callback

# Aliases also supported:
# DARAJA_CONSUMER_KEY=  DARAJA_CONSUMER_SECRET=  DARAJA_PASSKEY=  DARAJA_SHORTCODE=  DARAJA_CALLBACK_URL=
